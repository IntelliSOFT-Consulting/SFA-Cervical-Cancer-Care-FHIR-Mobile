<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardBackgroundColor="@color/recommendation_item_background"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:rippleColor="@color/recommendation_item_ripple"
    app:strokeColor="@color/recommendation_item_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:id="@+id/text_arrow_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/statusChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/recommendation_item_chip_background"
                android:fontFamily="@font/montserratsemi"
                android:includeFontPadding="false"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingStart="8dp"
                android:paddingTop="3dp"
                android:paddingEnd="8dp"
                android:paddingBottom="3dp"
                android:textColor="@color/recommendation_item_chip_text"
                android:textSize="10sp"
                android:visibility="gone"
                tools:text="Active"
                tools:visibility="visible" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/recommendation_item_arrow_background">

                <ImageView
                    android:id="@+id/arrowIcon"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/baseline_arrow_forward_ios_24"
                    app:tint="@color/recommendation_item_arrow_tint" />
            </FrameLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/textLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/montserratsemi"
            android:maxLines="3"
            android:textColor="@color/recommendation_item_title"
            android:textSize="16sp"
            tools:text="Schedule VIA screening and follow-up review for the patient." />

        <TextView
            android:id="@+id/detailText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:fontFamily="@font/montserratregular"
            android:maxLines="2"
            android:textColor="@color/recommendation_item_meta"
            android:textSize="13sp"
            tools:text="3 action items • Tap to review this recommendation" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
