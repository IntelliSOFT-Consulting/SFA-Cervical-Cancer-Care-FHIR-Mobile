<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:layout_margin="20dp"
    android:background="@drawable/patient_details_sheet_background"
    android:gravity="center_horizontal"
    android:orientation="vertical">

    <!-- Drag indicator -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp"
        android:background="@drawable/patient_details_sheet_drag_indicator" />

    <!-- Title -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="8dp"
        android:text="Send Recommendations to Patient"
        android:textAlignment="center"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:textColor="?attr/colorOnSurface"
        android:textStyle="bold" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="16dp"
        android:text="Choose how you want to send recommendations to the patient"
        android:textAlignment="center"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="14sp" />

    <!-- Communication Options -->
    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/whatsappCheck"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="WhatsApp"
        android:textColor="?attr/colorOnSurface"
        app:useMaterialThemeColors="true" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/emailCheck"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Email"
        android:textColor="?attr/colorOnSurface"
        app:useMaterialThemeColors="true" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/smsCheck"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SMS"
        android:textColor="?attr/colorOnSurface"
        app:useMaterialThemeColors="true" />

    <!-- Send Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/sendBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:backgroundTint="?attr/colorPrimary"
        android:text="Send Recommendations"
        android:textAllCaps="false"
        android:textColor="?attr/colorOnPrimary" />
</LinearLayout>
