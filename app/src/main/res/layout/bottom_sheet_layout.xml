<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginTop="12dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="20dp"
    android:background="@drawable/patient_details_sheet_background"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="16dp"
    android:paddingEnd="20dp"
    android:paddingBottom="24dp">

    <!-- Drag indicator -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:layout_marginBottom="18dp"
        android:background="@drawable/patient_details_sheet_drag_indicator" />

    <!-- Title -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/montserratbold"
        android:text="Send Recommendations to Patient"
        android:textAlignment="center"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:textColor="?attr/colorOnSurface"
        android:textStyle="bold" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="14dp"
        android:fontFamily="@font/montserratregular"
        android:text="Choose how you want to send recommendations to the patient"
        android:textAlignment="center"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="14sp" />

    <!-- Communication Options -->
    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/whatsappCheck"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:text="WhatsApp"
        android:textColor="?attr/colorOnSurface"
        app:useMaterialThemeColors="true" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/emailCheck"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:text="Email"
        android:textColor="?attr/colorOnSurface"
        app:useMaterialThemeColors="true" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/smsCheck"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:text="SMS"
        android:textColor="?attr/colorOnSurface"
        app:useMaterialThemeColors="true" />

    <!-- Send Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/sendBtn"
        style="@style/Widget.Material3.Button"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="18dp"
        android:backgroundTint="@color/patient_details_sheet_button_background"
        android:fontFamily="@font/montserratsemi"
        android:text="Send Recommendations"
        android:textAllCaps="false"
        android:textColor="@color/patient_details_sheet_button_text"
        android:textSize="15sp"
        app:cornerRadius="16dp"
        app:rippleColor="@color/patient_details_sheet_button_ripple"
        app:strokeColor="@color/patient_details_sheet_button_stroke"
        app:strokeWidth="1dp" />
</LinearLayout>
