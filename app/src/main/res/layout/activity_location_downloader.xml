<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/landing_screen_background"
    android:paddingStart="24dp"
    android:paddingTop="24dp"
    android:paddingEnd="24dp"
    android:paddingBottom="24dp"
    tools:context=".auth.LocationDownloaderActivity">

    <LinearLayout
        android:id="@+id/contentContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/landingLogo"
            android:layout_width="72dp"
            android:visibility="gone"
            android:layout_height="72dp"
            android:background="@drawable/login_logo_background"
            android:contentDescription="@string/app_name"
            android:padding="14dp"
            android:src="@mipmap/ic_launcher"
            app:tint="@color/login_logo_tint" />

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="@font/montserratbold"
            android:gravity="center"
            android:text="@string/location_downloader_title"
            android:textColor="@color/landing_title_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/montserratregular"
            android:gravity="center"
            android:text="@string/location_downloader_subtitle"
            android:textColor="@color/landing_subtitle_text"
            android:textSize="14sp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/syncCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            app:cardBackgroundColor="@color/location_card_background"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/location_card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="22dp"
                android:paddingEnd="20dp"
                android:paddingBottom="22dp">

                <TextView
                    android:id="@+id/syncBadgeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/location_badge_background"
                    android:fontFamily="@font/montserratsemi"
                    android:paddingStart="12dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="6dp"
                    android:textColor="@color/location_badge_text"
                    android:textSize="12sp" />

                <FrameLayout
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/location_sync_anim_background"
                    android:padding="20dp">

                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/animationView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:lottie_autoPlay="true"
                        app:lottie_rawRes="@raw/sync"
                        app:lottie_repeatCount="-1"
                        app:lottie_repeatMode="restart" />
                </FrameLayout>

                <TextView
                    android:id="@+id/syncingText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="@font/montserratsemi"
                    android:gravity="center"
                    android:text="@string/location_sync_enqueued"
                    android:textColor="@color/location_status_text_primary"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/syncDetailsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/montserratregular"
                    android:gravity="center"
                    android:text="@string/location_sync_running_detail"
                    android:textColor="@color/location_status_text_secondary"
                    android:textSize="13sp" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/syncProgressIndicator"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="18dp"
                    android:indeterminate="true"
                    app:indicatorColor="@color/location_progress_indicator"
                    app:trackColor="@color/location_progress_track"
                    app:trackCornerRadius="3dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/cancelButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="18dp"
                    android:backgroundTint="@color/location_action_button_bg"
                    android:fontFamily="@font/montserratsemi"
                    android:text="@string/location_sync_continue"
                    android:textAllCaps="false"
                    android:textColor="@color/location_action_button_text"
                    android:visibility="gone"
                    app:cornerRadius="14dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
